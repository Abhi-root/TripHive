<% layout('/template/boilerplate') %>
<body>
    <div class="col-8 offset-2">
                <h1>Sign Up On Wanderlust</h1>
                <form action="/signup" method="post" class=" needs-validation" novalidate>

                    <div>
                        <label for="username" class="form-label">Username</label><br>
                        <input type="text" placeholder="Enter Username" name="username" id="username" class="form-control"
                            required>
                        <div class="invalid-feedback">
                            Enter Username
                        </div><br><br>
                    </div>
                    <div>
                        <label for="email" class="form-label">Email</label><br>
                        <input type="email" placeholder="Enter Email" name="email" id="email" class="form-control"
                            required>
                        <div class="invalid-feedback">
                            Enter Email
                        </div><br><br>
                <div>
                    <label for="password" class="form-label">Password</label><br>
                    <input type="password" placeholder="Enter Password" name="password" id="password" class="form-control"
                        required>
                    <div class="invalid-feedback">
                        Enter Password
                    </div><br><br>
                </div>
                <div>
                    

                    <button type="submit" class="btn btn-dark">Submit</button>
                </form>
            </div>
    
    <script src="/script.js"></script>
</body>
