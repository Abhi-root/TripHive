<% layout('./template/boilerplate') -%>

    <body>
        <div class="col-8 offset-2">
            <h1>Edit Your Listing</h1>
            <form action="/alllisting/<%=data._id%>?_method=PUT" method="post">
                <div>
                    <label for="title" class="form-label">Title</label><br>
                    <input type="text" value="<%=data.title%>" name="title" id="title" class="form-control"><br><br>
                </div>

                <div>
                    <label for="description" class="form-label">Description</label><br>
                    <textarea name="description" id="description"
                        class="form-control"><%=data.description%></textarea><br><br>
                </div>

                <div>
                    <label for="image" class="form-label">Image Link</label><br>
                    <input type="text" name="url" value="<%=data.image.url%>" id="image"
                    class="form-control"><br><br>

                </div>

                <div>
                    <label for="location" class="form-label">Location</label><br>
                    <input type="text" value="<%=data.location%>" name="location" class="form-control"><br><br>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <label for="price" class="form-label">Price</label><br>
                        <input type="number" value="<%=data.price%>" name="price" id="price"
                            class="form-control"><br><br>
                    </div>

                    <div class="col-md-8">
                        <label for="country" class="form-label">Country</label><br>
                        <input type="text" value="<%=data.country%>" name="country" id="country"
                            class="form-control"><br><br>
                    </div>

                </div>

                <button type="submit" class="btn btn-primary">edit</button><br><br>
            </form>

        </div>

    </body>